rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }
    
    function isManager() {
      return request.auth != null && (getUserRole() == 'admin' || getUserRole() == 'manager');
    }
    
    function isUser() {
      return request.auth != null;
    }

    // Users collection - role-based access
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can update their own profile (except role)
      allow update: if request.auth != null && request.auth.uid == userId 
                   && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      // Users can create their own profile during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      // Only admins can read all users and update roles
      allow read, write: if isAdmin();
    }

    // Suppliers collection
    match /suppliers/{supplierId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Supplier Documents collection
    match /supplierDocuments/{documentId} {
      allow read, write: if isManager();
      allow read, create: if isUser();
      // Users can update/delete documents they uploaded
      allow update, delete: if isUser() && resource.data.uploadedBy == request.auth.uid;
    }

    // Products collection
    match /products/{productId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Product Categories collection (Procurement)
    match /productCategories/{categoryId} {
      // Managers/Admins can read/write categories
      allow read, write: if isManager();
      // All authenticated users can read categories
      allow read: if isUser();
    }

    // Purchase Orders collection (Procurement)
    match /purchaseOrders/{orderId} {
      // Managers/Admins full access
      allow read, write: if isManager();
      // Authenticated users can read and create orders
      allow read, create: if isUser();
      // Users can only update orders they created
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Documents collection
    match /documents/{documentId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Invoices collection (Procurement)
    match /invoices/{invoiceId} {
      // Managers/Admins full access
      allow read, write: if isManager();
      // Authenticated users can read and create invoices
      allow read, create: if isUser();
      // Users can only update invoices they created
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Payments collection (Procurement)
    match /payments/{paymentId} {
      // Managers/Admins full access
      allow read, write: if isManager();
      // Authenticated users can read and create payments
      allow read, create: if isUser();
      // Users can only update payments they created
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Shipments collection (Procurement)
    match /shipments/{shipmentId} {
      // Managers/Admins full access
      allow read, write: if isManager();
      // Authenticated users can read and create shipments
      allow read, create: if isUser();
      // Users can only update shipments they created
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Reports collection (admin only for now)
    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }

    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read, write: if isAdmin();
      allow read: if isUser(); // Users can read settings
    }

    // Audit logs (admin read-only)
    match /audit/{auditId} {
      allow read: if isAdmin();
      allow write: if false; // Audit logs are write-only via server functions
    }

    // User Supplier Access - Access control for supplier permissions
    match /userSupplierAccess/{accessId} {
      // Only admins can manage user-supplier access
      allow read, write: if isAdmin();
      // Users can read their own access permissions
      allow read: if isUser() && resource.data.userId == request.auth.uid;
    }

    // User Field Permissions - Field-level visibility control
    match /userFieldPermissions/{permissionId} {
      // Only admins can manage field permissions
      allow read, write: if isAdmin();
      // Users can read their own field permissions
      allow read: if isUser() && resource.data.userId == request.auth.uid;
    }

    // Organization Module Collections
    // Departments collection
    match /departments/{departmentId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Department Assignments collection
    match /departmentAssignments/{assignmentId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Tasks Module Collections
    // Tasks collection
    match /tasks/{taskId} {
      // Temporarily allow full access for authenticated users during development
      allow read, write: if isUser();
    }

    // Projects collection
    match /projects/{projectId} {
      // Temporarily allow full access for authenticated users during development
      allow read, write: if isUser();
    }

    // Comments collection for tasks and projects
    match /comments/{commentId} {
      allow read, write: if isUser();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, write: if isUser();
    }

    // Task Change Logs collection
    match /taskChangeLogs/{changeLogId} {
      allow read, write: if isUser();
    }

    // Sales Module Collections
    // Customers collection
    match /customers/{customerId} {
      allow read, write: if isManager();
      allow read, create: if isUser();
      // Users can update customers they created
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Sales Orders collection
    match /salesOrders/{orderId} {
      allow read, write: if isManager();
      allow read, create: if isUser();
      // Users can update their own sales orders
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Inventory Module Collections
    // Inventory Items collection
    match /inventoryItems/{itemId} {
      allow read, write: if isManager();
      allow read: if isUser();
      // Users can create new inventory items
      allow create: if isUser();
    }

    // Stock Levels collection
    match /stockLevels/{levelId} {
      allow read, write: if isManager();
      allow read: if isUser();
      // Stock levels are typically system-managed
    }

    // Stock Movements collection
    match /stockMovements/{movementId} {
      allow read, write: if isManager();
      allow read, create: if isUser();
      // Users can record stock movements
    }
  }
}
