rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }
    
    function isManager() {
      return request.auth != null && (getUserRole() == 'admin' || getUserRole() == 'manager');
    }
    
    function isUser() {
      return request.auth != null;
    }

    // Users collection - role-based access
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can update their own profile (except role)
      allow update: if request.auth != null && request.auth.uid == userId 
                   && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      // Only admins can read all users and update roles
      allow read, write: if isAdmin();
      // Only admins can create new users
      allow create: if isAdmin();
    }

    // Suppliers collection
    match /suppliers/{supplierId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Products collection
    match /products/{productId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Orders collection
    match /orders/{orderId} {
      allow read, write: if isManager();
      allow read, create: if isUser();
      // Users can only update their own orders
      allow update: if isUser() && resource.data.createdBy == request.auth.uid;
    }

    // Documents collection
    match /documents/{documentId} {
      allow read, write: if isManager();
      allow read: if isUser();
    }

    // Reports collection (admin only for now)
    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }

    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read, write: if isAdmin();
      allow read: if isUser(); // Users can read settings
    }

    // Audit logs (admin read-only)
    match /audit/{auditId} {
      allow read: if isAdmin();
      allow write: if false; // Audit logs are write-only via server functions
    }
  }
}
