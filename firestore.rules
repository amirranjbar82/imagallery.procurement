rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own profile documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Temporary open access for development - expires August 24, 2025
    // TODO: Replace with proper security rules before production
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2025, 8, 24);
    }
  }
}
